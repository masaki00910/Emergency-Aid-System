FROM python:3.11-slim

WORKDIR /app

COPY agents/analyzer/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY agents/analyzer/ ./agents/analyzer/
COPY agents/common/ ./agents/common/
COPY shared/ ./shared/

ENV PYTHONPATH=/app
ENV USE_MOCK_LLM=false
ENV PYTHONUNBUFFERED=1

EXPOSE 8080

WORKDIR /app/agents/analyzer

CMD ["python", "main.py"]